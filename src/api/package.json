{
    "name": "@webshop/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "esbuild-scripts watch",
        "build": "esbuild-scripts build",
        "preview": "node ../../dist/api/index.js",
        "build:vercel": "esbuild src/index.ts --bundle --platform=node --format=ts --outfile=../../dist/api/index.ts",
        "test": "vitest --run --coverage",
        "test:watch": "vitest",
        "test:watch-with-coverage": "vitest --coverage",
        "test:ui": "vitest --coverage --ui"
    },
    "dependencies": {
        "@hboictcloud/metadata": "^1.0.2",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "1.4.7",
        "cors": "2.8.5",
        "dotenv": "16.4.7",
        "express": "^4.22.1",
        "express-async-errors": "3.1.1",
        "mysql2": "3.14.0",
        "resend": "^6.9.2"
    },
    "devDependencies": {
        "@hboictcloud/esbuild-plugin-interfaces": "^1.x",
        "@hboictcloud/esbuild-plugin-typechecks": "^1.x",
        "@hboictcloud/esbuild-scripts": "^1.x",
        "@types/cookie-parser": "1.4.8",
        "@types/cors": "2.8.17",
        "@types/express": "4.17.21",
        "@types/supertest": "6.0.3",
        "esbuild": "0.25.2",
        "supertest": "7.1.0"
    }
}
